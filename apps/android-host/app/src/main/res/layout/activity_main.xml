<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tagline"
        android:textSize="13sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/goOnlineBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/go_online" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/your_id"
        android:textSize="13sp"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/myId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textSize="30sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pin"
        android:textSize="13sp"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/myPin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textSize="30sp"
        android:textStyle="bold"
        android:letterSpacing="0.2" />

    <Button
        android:id="@+id/newPinBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/new_pin"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/enableControlBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enable_control"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/enableFilesBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enable_files"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/rootBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/use_root"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/offline"
        android:textSize="14sp"
        android:layout_marginTop="32dp"
        android:gravity="center" />
</LinearLayout>
