{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "controller-app",
  "version": "0.1.0",
  "identifier": "com.nikhil.controller-app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "UpDesk Controller",
        "width": 1100,
        "height": 720,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection,CalculateNativeWinOcclusion --disable-background-timer-throttling --disable-backgrounding-occluded-windows --disable-renderer-backgrounding --ignore-certificate-errors-spki-list=CDFj8Bx2PjooDMLBSJOorx8OXHi52I9PKfnF08wI76Y="
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
